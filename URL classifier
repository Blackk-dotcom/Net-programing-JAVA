import java.net.*; import java.util.Scanner;
public class UrlUriClassifier {
public static void main(String[] args){
Scanner sc=new Scanner(System.in);
while(true){
System.out.print("Input: "); String input=sc.nextLine().trim();
if(input.isEmpty()) break;
try{ URI uri=new URI(input); try{ URL url=uri.toURL();
System.out.println("URL and URI: "+url.getProtocol()); } catch(Exception e){
System.out.println("URI but not URL. Scheme: "+uri.getScheme()); }}
catch(Exception e){ System.out.println("Invalid URI/URL"); }
}
}
}

import java.net.*; import java.util.*;
public class IpClassifier {
public static void main(String[] args){
Scanner sc = new Scanner(System.in);
while(true){
System.out.print("IP: "); String value = sc.nextLine().trim();
if(value.isEmpty()) break;
try{
InetAddress a = InetAddress.getByName(value);
if(value.contains(":")) System.out.println(value + " is IPv6");
else if(value.matches("(\\d{1,3}\\.){3}\\d{1,3}"))
System.out.println(value + " is IPv4");
else System.out.println(value + " is not a direct IP literal");
} catch(Exception e){ System.out.println(value + " is invalid"); }
}
}
}
